<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/jitsi/db" VERSION="2025122000" COMMENT="XMLDB file for Moodle mod/jitsi"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="jitsi" COMMENT="Default comment for jitsi, please edit me">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" UNSIGNED="true" SEQUENCE="true"/>
        <FIELD NAME="course" TYPE="int" LENGTH="10" NOTNULL="true" UNSIGNED="true" SEQUENCE="false" COMMENT="Course jitsi activity belongs to"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="name field for moodle instances"/>
        <FIELD NAME="intro" TYPE="text" NOTNULL="true" SEQUENCE="false" COMMENT="General introduction of the jitsi activity"/>
        <FIELD NAME="introformat" TYPE="int" LENGTH="4" NOTNULL="true" UNSIGNED="true" DEFAULT="0" SEQUENCE="false" COMMENT="Format of the intro field (MOODLE, HTML, MARKDOWN...)"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" UNSIGNED="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" UNSIGNED="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timeopen" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timeclose" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="validitytime" TYPE="int" LENGTH="10" NOTNULL="false" UNSIGNED="true" SEQUENCE="false"/>
        <FIELD NAME="minpretime" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="token" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false" COMMENT="Sha256 for invitations"/>
        <FIELD NAME="completionminutes" TYPE="int" LENGTH="3" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="50" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="numberofparticipants" TYPE="int" LENGTH="3" NOTNULL="true" UNSIGNED="true" DEFAULT="0" SEQUENCE="false" COMMENT="Number of participants"/>
        <FIELD NAME="sourcerecord" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="sessionwithtoken" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" UNSIGNED="true" SEQUENCE="false" COMMENT="Session bassed on other"/>
        <FIELD NAME="tokeninvitacion" TYPE="char" LENGTH="255" NOTNULL="false" DEFAULT="" SEQUENCE="false" COMMENT="Token from session master"/>
        <FIELD NAME="tokeninterno" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false" COMMENT="Sha256 for share sessions with other courses"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="course" UNIQUE="false" FIELDS="course"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="jitsi_record" COMMENT="Jitsi records">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" UNSIGNED="true" SEQUENCE="true"/>
        <FIELD NAME="jitsi" TYPE="int" LENGTH="10" NOTNULL="true" UNSIGNED="true" SEQUENCE="false" COMMENT="Jitsi session id"/>
        <FIELD NAME="deleted" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" UNSIGNED="true" SEQUENCE="false" COMMENT="Record to delete"/>
        <FIELD NAME="source" TYPE="int" LENGTH="10" NOTNULL="false" UNSIGNED="true" SEQUENCE="false" COMMENT="Source record"/>
        <FIELD NAME="visible" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1" UNSIGNED="true" SEQUENCE="false" COMMENT="Record visible"/>
        <FIELD NAME="name" TYPE="text" NOTNULL="true" SEQUENCE="false" COMMENT="name field for moodle instances"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="jitsi" UNIQUE="false" FIELDS="jitsi"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="jitsi_record_account" COMMENT="Accounts to records or streaming">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" UNSIGNED="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Name account"/>
        <FIELD NAME="clientaccesstoken" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Access Token "/>
        <FIELD NAME="clientrefreshtoken" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Refresh Token "/>
        <FIELD NAME="tokencreated" TYPE="int" LENGTH="10" NOTNULL="false" UNSIGNED="true" SEQUENCE="false"/>
        <FIELD NAME="inuse" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" UNSIGNED="true" SEQUENCE="false" COMMENT="Account in use"/>
        <FIELD NAME="inqueue" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" UNSIGNED="true" SEQUENCE="false" COMMENT="Account in queue"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="jitsi_source_record" COMMENT="Accounts to records or streaming">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" UNSIGNED="true" SEQUENCE="true"/>
        <FIELD NAME="link" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="link of the record"/>
        <FIELD NAME="account" TYPE="int" LENGTH="10" NOTNULL="false" UNSIGNED="true" SEQUENCE="false" COMMENT="Account"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" UNSIGNED="true" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="embed" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" UNSIGNED="true" SEQUENCE="false" COMMENT="Video embeddable"/>
        <FIELD NAME="maxparticipants" TYPE="int" LENGTH="3" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="type" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" UNSIGNED="true" SEQUENCE="false" COMMENT="Source type: 0=YouTube, 1=external link from recordingLinkAvailable"/>
        <FIELD NAME="timeexpires" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Unix timestamp when the recording link expires (0 = never)"/>
        <FIELD NAME="ai_summary" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="AI-generated summary of the recording"/>
        <FIELD NAME="ai_quiz_id" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Course module ID of the AI-generated quiz (0 = none)"/>
        <FIELD NAME="ai_transcription" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="AI-generated timestamped transcription of the recording"/>
        <FIELD NAME="ai_transcription_status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="" SEQUENCE="false" COMMENT="Transcription status: empty=none, pending, done, error"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="jitsi_servers" COMMENT="Jitsi servers configuration">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="false" DEFAULT=""/>
        <FIELD NAME="type" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="domain" TYPE="char" LENGTH="255" NOTNULL="false" DEFAULT=""/>
        <FIELD NAME="appid" TYPE="char" LENGTH="255" NOTNULL="false" DEFAULT=""/>
        <FIELD NAME="secret" TYPE="char" LENGTH="255" NOTNULL="false" DEFAULT=""/>
        <FIELD NAME="eightbyeightappid" TYPE="char" LENGTH="255" NOTNULL="false" DEFAULT=""/>
        <FIELD NAME="eightbyeightapikeyid" TYPE="char" LENGTH="255" NOTNULL="false" DEFAULT=""/>
        <FIELD NAME="privatekey" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="gcpproject" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="GCP project ID"/>
        <FIELD NAME="gcpzone" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false" COMMENT="GCP zone"/>
        <FIELD NAME="gcpinstancename" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="GCP instance name"/>
        <FIELD NAME="gcpstaticipname" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="GCP static IP address name"/>
        <FIELD NAME="gcpstaticipaddress" TYPE="char" LENGTH="45" NOTNULL="false" DEFAULT="" SEQUENCE="false" COMMENT="GCP static IP address (IPv4)"/>
        <FIELD NAME="provisioningstatus" TYPE="char" LENGTH="50" NOTNULL="false" DEFAULT="" SEQUENCE="false" COMMENT="Provisioning status: provisioning, ready, error"/>
        <FIELD NAME="provisioningtoken" TYPE="char" LENGTH="64" NOTNULL="false" DEFAULT="" SEQUENCE="false" COMMENT="Security token for VM callback authentication"/>
        <FIELD NAME="provisioningerror" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Error message if provisioning failed"/>
        <FIELD NAME="jibri_enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Whether a dedicated Jibri recording VM is enabled for this server"/>
        <FIELD NAME="jibri_gcpinstancename" TYPE="char" LENGTH="255" NOTNULL="false" DEFAULT="" SEQUENCE="false" COMMENT="GCP instance name of the Jibri VM"/>
        <FIELD NAME="jibri_provisioningstatus" TYPE="char" LENGTH="50" NOTNULL="false" DEFAULT="" SEQUENCE="false" COMMENT="Provisioning status of the Jibri VM"/>
        <FIELD NAME="jibri_provisioningerror" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Error message if Jibri VM provisioning failed"/>
        <FIELD NAME="jibri_xmpp_pass" TYPE="char" LENGTH="64" NOTNULL="false" DEFAULT="" SEQUENCE="false" COMMENT="XMPP password for the Jibri Prosody user"/>
        <FIELD NAME="jibri_recorder_pass" TYPE="char" LENGTH="64" NOTNULL="false" DEFAULT="" SEQUENCE="false" COMMENT="XMPP password for the recorder Prosody user"/>
        <FIELD NAME="gcs_enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Whether GCS upload is enabled for Jibri recordings"/>
        <FIELD NAME="gcs_bucket" TYPE="char" LENGTH="255" NOTNULL="false" DEFAULT="" SEQUENCE="false" COMMENT="GCS bucket name for Jibri recordings"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="jitsi_push_subscriptions" COMMENT="Web Push subscriptions for private session notifications">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Moodle user ID"/>
        <FIELD NAME="endpoint" TYPE="text" NOTNULL="true" SEQUENCE="false" COMMENT="Push endpoint URL"/>
        <FIELD NAME="authkey" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT="" SEQUENCE="false" COMMENT="Auth key (base64url)"/>
        <FIELD NAME="p256dhkey" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT="" SEQUENCE="false" COMMENT="p256dh key (base64url)"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid" UNIQUE="false" FIELDS="userid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="jitsi_tutoring_schedule" COMMENT="Tutoring availability schedule for private sessions">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Teacher user ID"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Course ID"/>
        <FIELD NAME="weekday" TYPE="int" LENGTH="1" NOTNULL="true" SEQUENCE="false" COMMENT="Day of week: 0=Sunday, 1=Monday ... 6=Saturday"/>
        <FIELD NAME="timestart" TYPE="int" LENGTH="5" NOTNULL="true" SEQUENCE="false" COMMENT="Seconds from midnight in teacher timezone"/>
        <FIELD NAME="timeend" TYPE="int" LENGTH="5" NOTNULL="true" SEQUENCE="false" COMMENT="Seconds from midnight in teacher timezone"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_courseid" UNIQUE="false" FIELDS="userid, courseid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
