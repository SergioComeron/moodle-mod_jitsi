{{!
    @template mod_jitsi/segments_bar

    A horizontal bar showing which parts of a recording a single user watched.

    Context variables required for this template:
    * barid string - Optional id attribute for the bar (empty for none)
    * segments array - Watched segments as left/width percentages

    Example context (json):
    {
        "barid": "jitsi-segbar-12",
        "segments": [
            {"left": "0.00", "width": "50.00"},
            {"left": "75.00", "width": "25.00"}
        ]
    }
}}
<div {{#barid}}id="{{barid}}" {{/barid}}class="jitsi-segbar"
    style="position:relative;height:8px;background:#dee2e6;border-radius:4px;overflow:hidden">
    {{#segments}}
        <div style="position:absolute;left:{{left}}%;width:{{width}}%;height:100%;background:#0d6efd"></div>
    {{/segments}}
</div>
