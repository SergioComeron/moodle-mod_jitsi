{{!
    @template mod_jitsi/view_recording_external

    A recording row for non-embeddable external links (8x8, offline Jibri, other
    files): the recording name, creation date, action buttons and an open/download
    button.

    Context variables required for this template:
    * inplacename string - pre-rendered inplace-editable recording name
    * timecreated string - localised creation date
    * jibriwarn string - pre-rendered offline warning icon (may be empty)
    * candelete bool, canhidetoggle bool, visible bool, canedit bool, recordid int, cmid int
        - see mod_jitsi/view_recording_actions
    * openurl string - recording link
    * openlabel string - open/download button label
    * sourcerecordid int - jitsi_source_record id
    * aidropdown string - pre-rendered AI generate dropdown (may be empty)
    * aiaccordion string - pre-rendered accordion with generated AI content (may be empty)

    Example context (json):
    {
        "inplacename": "<span>My recording</span>",
        "timecreated": "1 January 2026",
        "jibriwarn": "",
        "candelete": true,
        "canhidetoggle": false,
        "visible": true,
        "canedit": false,
        "recordid": 5,
        "cmid": 12,
        "openurl": "https://8x8.vc/rec",
        "openlabel": "Download",
        "sourcerecordid": 9,
        "aidropdown": "",
        "aiaccordion": ""
    }
}}
<div class="py-1">
    <div class="d-flex align-items-center gap-2">
        <span class="flex-grow-1">
            {{{inplacename}}}{{{jibriwarn}}}
            <small class="text-muted ms-2">{{timecreated}}</small>
        </span>
        <span class="text-nowrap">
            {{> mod_jitsi/view_recording_actions }}{{{aidropdown}}}<a href="{{openurl}}" target="_blank"
                class="btn btn-sm btn-primary jitsi-recording-link ms-1"
                data-sourcerecordid="{{sourcerecordid}}" data-cmid="{{cmid}}">{{openlabel}}</a>
        </span>
    </div>
    {{{aiaccordion}}}
</div>
