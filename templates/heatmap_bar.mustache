{{!
    @template mod_jitsi/heatmap_bar

    Aggregate viewing heatmap for a recording: a blue bar of unique viewers per
    10s bucket and an optional orange bar of total plays per bucket.

    Context variables required for this template:
    * viewerlabel string - Heading text (heatmap title and viewer count)
    * viewersjson string - JSON map of viewer names per bucket (for the tooltip JS)
    * bucketsize int - Bucket size in seconds
    * viewerbuckets array - Non-empty viewer buckets: bucket, start, end, left, width, opacity
    * hasplays bool - Whether the total-plays bar should be shown
    * playslabel string - Heading text for the plays bar
    * playbuckets array - Non-empty play buckets: title, left, width, opacity

    Example context (json):
    {
        "viewerlabel": "Viewing heatmap — 2 viewers",
        "viewersjson": "{\"0\":[\"Ada Lovelace\"]}",
        "bucketsize": 10,
        "viewerbuckets": [
            {"bucket": 0, "start": "0s", "end": "10s", "left": "0.000", "width": "100.100", "opacity": "1.000"}
        ],
        "hasplays": true,
        "playslabel": "Total plays (max 3)",
        "playbuckets": [
            {"title": "3 plays · 0s–10s", "left": "0.000", "width": "100.100", "opacity": "1.000"}
        ]
    }
}}
<div class="mt-3">
    <small class="text-muted d-block mb-1">{{viewerlabel}}</small>
    <div class="jitsi-heatmap mb-1" data-viewers="{{viewersjson}}" data-bucketsize="{{bucketsize}}"
        style="position:relative;height:8px;background:#dee2e6;border-radius:4px;overflow:hidden;cursor:crosshair">
        {{#viewerbuckets}}
            <div data-bucket="{{bucket}}" data-start="{{start}}" data-end="{{end}}"
                style="position:absolute;left:{{left}}%;width:{{width}}%;height:100%;background:rgba(13,110,253,{{opacity}})"></div>
        {{/viewerbuckets}}
    </div>
    {{#hasplays}}
        <small class="text-muted d-block mb-1">{{playslabel}}</small>
        <div class="jitsi-heatmap"
            style="position:relative;height:8px;background:#dee2e6;border-radius:4px;overflow:hidden;cursor:default">
            {{#playbuckets}}
                <div title="{{title}}"
                    style="position:absolute;left:{{left}}%;width:{{width}}%;height:100%;background:rgba(253,126,20,{{opacity}})"></div>
            {{/playbuckets}}
        </div>
    {{/hasplays}}
</div>
