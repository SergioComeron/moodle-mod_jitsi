{{!
    @template mod_jitsi/view_session_header

    Session tab header: live connected-attendees + user-minutes metrics and status badges.

    The ids jitsi-presence-count, jitsi-presence-list, jitsi-user-minutes and
    jitsi-jibri-badge are refreshed live by the mod_jitsi/view_indicators AMD module.

    Context variables required for this template:
    * bstoggle string - "data-bs-toggle" (BS5) or "data-toggle" (BS4)
    * presencecount int - current connected attendees count
    * presenceusers array - [{name, isguest, profileurl}]
    * hasusers bool - whether presenceusers is non-empty
    * connectedlabel string - "connected attendees now" label
    * nouserslabel string - "no connected users" label
    * userminutes int - current user's total connected minutes
    * minuteslabel string - "total user minutes" label
    * sharedbadge string - shared-session label, or empty/false to hide
    * recordingby string - "is being recorded by X" label, or empty/false to hide
    * jibrihidden bool - whether the Jibri recording badge starts hidden
    * jibrilabel string - "is being recorded" label

    Example context (json):
    {
        "bstoggle": "data-bs-toggle",
        "presencecount": 2,
        "presenceusers": [{"name": "Ada Lovelace", "isguest": false, "profileurl": "#"}],
        "hasusers": true,
        "connectedlabel": "Connected attendees now",
        "nouserslabel": "No connected users",
        "userminutes": 12,
        "minuteslabel": "Total user minutes",
        "sharedbadge": "Shared from MATH101",
        "recordingby": "",
        "jibrihidden": true,
        "jibrilabel": "This session is being recorded"
    }
}}
<div class="d-flex justify-content-center gap-5 mt-3 mb-3">
    <div class="text-center">
        <div class="dropdown d-inline-block">
            <button class="border-0 bg-transparent p-0 dropdown-toggle" id="jitsi-presence-btn"
                {{bstoggle}}="dropdown" aria-expanded="false" aria-label="{{connectedlabel}}">
                <span id="jitsi-presence-count" class="h4 mb-0 fw-bold">{{presencecount}}</span>
            </button>
            <ul class="dropdown-menu" id="jitsi-presence-list" aria-labelledby="jitsi-presence-btn">
                {{#presenceusers}}
                    {{#isguest}}
                        <li><span class="dropdown-item-text"><i class="fa fa-user-secret text-muted me-1" aria-hidden="true"></i>{{name}}</span></li>
                    {{/isguest}}
                    {{^isguest}}
                        <li><a class="dropdown-item" href="{{profileurl}}" target="_blank" rel="noopener">{{name}}</a></li>
                    {{/isguest}}
                {{/presenceusers}}
                {{^hasusers}}
                    <li><span class="dropdown-item-text text-muted">{{nouserslabel}}</span></li>
                {{/hasusers}}
            </ul>
        </div>
        <div class="text-muted small">{{connectedlabel}}</div>
    </div>
    <div class="text-center">
        <div class="h4 mb-0 fw-bold" id="jitsi-user-minutes">{{userminutes}}</div>
        <div class="text-muted small">{{minuteslabel}}</div>
    </div>
</div>
<div class="text-center mb-2">
    {{#sharedbadge}}
        <span class="badge bg-secondary me-2">🔗 {{sharedbadge}}</span>
    {{/sharedbadge}}
    {{#recordingby}}
        <span class="badge bg-danger me-1"><i class="fa fa-circle me-1" aria-hidden="true"></i>{{recordingby}}</span>
    {{/recordingby}}
    <span class="badge bg-danger me-1{{#jibrihidden}} d-none{{/jibrihidden}}" id="jitsi-jibri-badge"><i class="fa fa-circle me-1" aria-hidden="true"></i>{{jibrilabel}}</span>
</div>
