{{!
    @template mod_jitsi/view_tabs_nav

    Navigation tabs (Session / Records) for the activity view.

    Context variables required for this template:
    * bstoggle string - "data-bs-toggle" (BS5) or "data-toggle" (BS4)
    * sessionactive bool - whether the Session tab is the active one
    * sessionlabel string - Session tab label
    * showrecordtab bool - whether to show the Records tab
    * recordactive bool - whether the Records tab is the active one
    * recordlabel string - Records tab label

    Example context (json):
    {
        "bstoggle": "data-bs-toggle",
        "sessionactive": true,
        "sessionlabel": "Session",
        "showrecordtab": true,
        "recordactive": false,
        "recordlabel": "Records"
    }
}}
<ul class="nav nav-tabs" id="myTab" role="tablist">
    <li class="nav-item">
        <a class="nav-link {{#sessionactive}}active{{/sessionactive}}" id="session-tab"
            {{bstoggle}}="tab" href="#session" role="tab" aria-controls="session"
            aria-selected="{{#sessionactive}}true{{/sessionactive}}{{^sessionactive}}false{{/sessionactive}}">{{sessionlabel}}</a>
    </li>
    {{#showrecordtab}}
    <li class="nav-item">
        <a class="nav-link {{#recordactive}}active{{/recordactive}}" id="record-tab"
            {{bstoggle}}="tab" href="#record" role="tab" aria-controls="record"
            aria-selected="{{#recordactive}}true{{/recordactive}}{{^recordactive}}false{{/recordactive}}">{{recordlabel}}</a>
    </li>
    {{/showrecordtab}}
</ul>
