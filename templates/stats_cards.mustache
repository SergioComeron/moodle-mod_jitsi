{{!
    @template mod_jitsi/stats_cards

    Row of summary stat cards (value + label) used by the usage and
    attendance reports. Set smallcards for the compact variant.

    Example context (json):
    {
        "rowclass": "mb-4",
        "colclass": "col-md-3 col-sm-6 mb-3",
        "smallcards": false,
        "cards": [
            {"value": "42", "label": "Total sessions"},
            {"value": "2h 30min", "label": "Total minutes"}
        ]
    }
}}
<div class="row {{rowclass}}">
    {{#cards}}
    <div class="{{colclass}}">
        <div class="card h-100 text-center border-0 bg-light">
            <div class="card-body {{#smallcards}}py-2{{/smallcards}}{{^smallcards}}py-3{{/smallcards}}">
                <div class="{{#smallcards}}h3 mb-0{{/smallcards}}{{^smallcards}}h2 mb-1{{/smallcards}} fw-bold">{{value}}</div>
                <div class="text-muted small">{{label}}</div>
            </div>
        </div>
    </div>
    {{/cards}}
</div>
