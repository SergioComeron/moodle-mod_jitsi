{{!
    @template mod_jitsi/stats_table

    Generic report table. Header and cell entries are pre-built HTML-safe
    strings (links already escaped by the caller via format_string/html_writer).

    Example context (json):
    {
        "tableclass": "table-sm",
        "head": ["Name", "Sessions"],
        "rows": [
            {"cells": ["Alice", "5"]},
            {"cells": ["Bob", "3"]}
        ]
    }
}}
<table class="generaltable{{#tableclass}} {{tableclass}}{{/tableclass}}">
    <thead>
        <tr>
            {{#head}}<th>{{{.}}}</th>{{/head}}
        </tr>
    </thead>
    <tbody>
        {{#rows}}
        <tr>
            {{#cells}}<td>{{{.}}}</td>{{/cells}}
        </tr>
        {{/rows}}
    </tbody>
</table>
