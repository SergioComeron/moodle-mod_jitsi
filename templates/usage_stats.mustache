{{!
    @template mod_jitsi/usage_stats

    Session usage statistics page: back button, filter form, summary cards
    and one card section per report (monthly chart+table, top courses,
    top categories, top users) with export selectors.

    Example context (json):
    {
        "backurl": "https://example.com/admin/settings.php?section=modsettingjitsi",
        "backlabel": "Back to settings",
        "formhtml": "<form></form>",
        "rowclass": "mb-4",
        "colclass": "col-md-3 col-sm-6 mb-3",
        "smallcards": false,
        "cards": [{"value": "42", "label": "Total sessions"}],
        "nodatahtml": null,
        "sections": [
            {
                "title": "Monthly usage",
                "toplimit": null,
                "charthtml": "<div>chart</div>",
                "tableclass": "mt-3",
                "head": ["Month", "Sessions"],
                "rows": [{"cells": ["2026-01", "10"]}],
                "downloadhtml": "<form>download</form>"
            }
        ]
    }
}}
<a href="{{backurl}}" class="btn btn-secondary mb-4">← {{backlabel}}</a>

<div class="card mb-4">
    <div class="card-body">
        {{{formhtml}}}
    </div>
</div>

{{> mod_jitsi/stats_cards }}

{{{nodatahtml}}}

{{#sections}}
<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h3 class="mb-0">{{title}}</h3>
        {{#toplimit}}
        <span class="float-end small text-muted mt-1">{{label}}:
            {{#options}}{{#notfirst}} | {{/notfirst}}{{#current}}<strong>{{n}}</strong>{{/current}}{{^current}}<a href="{{url}}">{{n}}</a>{{/current}}{{/options}}</span>
        {{/toplimit}}
    </div>
    <div class="card-body">
        {{{charthtml}}}
        {{> mod_jitsi/stats_table }}
        {{{downloadhtml}}}
    </div>
</div>
{{/sections}}
